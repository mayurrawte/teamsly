# Microsoft Azure AD App Registration
# Create at: https://portal.azure.com > Azure Active Directory > App registrations
AZURE_AD_CLIENT_ID=your-client-id-here
AZURE_AD_CLIENT_SECRET=your-client-secret-here
AZURE_AD_TENANT_ID=common

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# LiveKit Cloud — voice rooms
# Create a project at https://cloud.livekit.io, then copy from Project Settings
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Optional — higher GitHub API rate limit for PR/issue cards (60/hr without, 5000/hr with)
GITHUB_TOKEN=

# Real-time channel messages via Graph webhooks need these Microsoft Graph permissions:
# - ChannelMessage.Read.All (delegated)
# Subscriptions require the app to be publicly reachable.
# In local dev, you need to use an ngrok tunnel:
#   ngrok http 3000
# Then override the webhook URL via:
# GRAPH_WEBHOOK_BASE_URL=https://your-tunnel.ngrok-free.app
GRAPH_WEBHOOK_BASE_URL=
