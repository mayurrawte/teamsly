# RSA key pair for decrypting Graph change-notification encrypted payloads.
#
# Generate once with:
#   openssl genrsa -out webhook_private.pem 2048
#   openssl rsa -in webhook_private.pem -pubout -out webhook_public.pem
#
# Paste the file contents below, replacing real newlines with \n so the value
# fits on a single line (required by most .env parsers).

WEBHOOK_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
WEBHOOK_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Arbitrary stable identifier registered with Microsoft Graph when subscribing.
WEBHOOK_RSA_CERT_ID="teamsly-key-v1"
