{
  "name": "teamsly",
  "version": "0.6.2",
  "private": false,
  "description": "Open-source modern client for Microsoft Teams",
  "license": "AGPL-3.0",
  "author": {
    "name": "Mayur Rawte",
    "email": "mayur@shipthis.co"
  },
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "electron:compile": "tsc -p electron",
    "electron:dev": "npm run electron:compile && electron electron/dist/main.js",
    "electron:dev:all": "concurrently -k -n next,electron -c blue,magenta \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "electron:build": "npm run electron:compile && electron-builder --publish never",
    "electron:release": "electron-builder --publish always",
    "test": "vitest run"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.17.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@livekit/components-react": "^2.9.23",
    "@livekit/components-styles": "^1.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "emoji-mart": "^5.6.0",
    "html-react-parser": "^6.1.4",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "^2.17.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.25",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-textarea-autosize": "^8.5.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "postcss": "8.5.19",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
