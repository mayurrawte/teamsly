{
  "name": "teamsly",
  "version": "0.4.0",
  "private": false,
  "description": "Open-source modern client for Microsoft Teams",
  "license": "AGPL-3.0",
  "author": {
    "name": "Mayur Rawte",
    "email": "mayur@shipthis.co"
  },
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "electron:compile": "tsc -p electron",
    "electron:dev": "npm run electron:compile && electron electron/dist/main.js",
    "electron:dev:all": "concurrently -k -n next,electron -c blue,magenta \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "electron:build": "npm run electron:compile && electron-builder --publish never",
    "electron:release": "electron-builder --publish always"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@azure/msal-browser": "^5.11.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.3",
    "emoji-mart": "^5.6.0",
    "html-react-parser": "^6.1.3",
    "livekit-client": "^2.19.1",
    "livekit-server-sdk": "^2.15.4",
    "lucide-react": "^0.477.0",
    "next": "15.5.18",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-textarea-autosize": "^8.5.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "postcss": "8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6",
    "wait-on": "^8.0.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
